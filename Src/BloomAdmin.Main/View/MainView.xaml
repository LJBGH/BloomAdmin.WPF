<Window x:Class="BloomAdmin.Main.View.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BloomAdmin.Main.View"
        xmlns:converter="clr-namespace:BloomAdmin.Main.Common.Converter"
        mc:Ignorable="d"
        Title="朝夕教育" Height="800" Width="1250"
        FontFamily="Microsoft YaHei" FontWeight="ExtraLight" FontSize="12"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="{x:Null}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary  Source="/Styles/DefaultStyle.xaml">
                    <converter:GenderConverter x:Key="GenderConverter"/>
                    <!--导航栏样式-->
                    <Style TargetType="RadioButton" x:Key="NavButtonStyle">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border Background="Transparent" CornerRadius="8" Name="back">
                                        <ContentControl Content="{TemplateBinding Content}"
                                                        HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Margin="20,3"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="back" Property="Background" Value="#44FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <ControlTemplate TargetType="Button" x:Key="TabButtonTemplate">
                        <Border Name="back"  CornerRadius="15" 
                                Width="60" Height="30" Background="Transparent">
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="back" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="back" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    <!--搜索框样式-->
                    <SolidColorBrush x:Key="SearchTextBoxStaticBorder" Color="#FFABAdB3"/>
                    <SolidColorBrush x:Key="SearchTextBoxMouseOverBorder" Color="#FF7EB4EA"/>
                    <SolidColorBrush x:Key="SearchTextBoxFocusBorder" Color="#FF569DE5"/>
                    <!--搜索框-->
                    <ControlTemplate TargetType="{x:Type TextBox}" x:Key="SearchTextBoxTemplate" >
                        <Border x:Name="border"
                        Background="#22000000"
                        BorderThickness="0" 
                        SnapsToDevicePixels="True"
                        CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xe6eb;" FontSize="18" Foreground="White"
                                   TextAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="{StaticResource IconFont}"
                                   Opacity ="0.7"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" 
                                           Text=" Search for with you like..." Foreground="#44FFFFFF" 
                                           Visibility="Collapsed" Name="defulttext"/>
                                <ScrollViewer Grid.Column="1" x:Name="PART_ContentHost" Focusable="false" 
                                              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" TargetName="border" Value="0.56"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource SearchTextBoxMouseOverBorder}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource SearchTextBoxFocusBorder}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                <Setter TargetName="defulttext" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    <!--自定义单选框-->
                    <ControlTemplate x:Key="GenderRadioButtonTemplate" TargetType="{x:Type RadioButton}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="16" Height="16" Background="White" CornerRadius="50" BorderThickness="2" 
                                    BorderBrush="#3D4455" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Border Width="10" Height="10" Background="#3D4455" CornerRadius="50" BorderThickness="0.5" 
                                    VerticalAlignment="Center" Name="point" Visibility="Collapsed"></Border>
                            </Border>
                            <ContentControl Grid.Column="1" Content="{TemplateBinding Content }" Foreground="White" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Visibility"  Value="Visible" TargetName="point" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    <!--用户信息侧边栏动画-->
                    <Storyboard x:Key="ShowUserInfoStoyboard">
                        <DoubleAnimation Duration="0:0:0.2" To="0"
                                         Storyboard.TargetName="tt"
                                         Storyboard.TargetProperty="X"/>
                    </Storyboard>
                    <Storyboard x:Key="CloseUserInfoStoyboard">
                        <DoubleAnimation Duration="0:0:0.1"
                              Storyboard.TargetName="tt"
                              Storyboard.TargetProperty="X"/>
                    </Storyboard>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Button.Click" SourceName="btnUserInfo">
            <BeginStoryboard Storyboard="{StaticResource ShowUserInfoStoyboard}"/>
        </EventTrigger>
        <EventTrigger RoutedEvent="Button.Click" SourceName="btnCloseUserInfo">
            <BeginStoryboard Storyboard="{StaticResource CloseUserInfoStoyboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Margin="5" Background="#FFF1F1F1" CornerRadius="20" >
        <Border.Effect>
            <DropShadowEffect Color="Gray" ShadowDepth="0" BlurRadius="20" Opacity="0.3" Direction="0"/>
        </Border.Effect>
        <Grid>
            <Border Height="160" VerticalAlignment="Top" CornerRadius="20,20,0,0"
                        MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF4CA8FD"/>
                        <GradientStop Color="#FF0061FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <!--窗口控制按钮-->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" 
                            Margin="0,8,8,0">
                <Button Name="btnMin" Content="&#xe65a;" Style= "{StaticResource WindowControlButtonStyle}" Click="btnMin_Click"/>
                <Button Name="btnMax" Content="&#xe65d;" Style="{StaticResource WindowControlButtonStyle}" Click="btnMax_Click"/>
                <Button Name="btnClose" Content="&#xe660;" Style="{StaticResource WindowControlButtonStyle}" Click="btnClose_Click"/>
            </StackPanel>
            <Grid Margin="10,30,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Source="/Assets/Images/Logo.png" Width="40" Height="40"></Image>
                    <StackPanel Margin="10,0,0,0" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="朝夕教育课程管理平台" Foreground="White" FontSize="20"></TextBlock>
                        <TextBlock Text="ZHAOXI EDU"  Opacity="0.8" Foreground="#FFB3B3B3"></TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Margin="0,0,20,0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border CornerRadius="50" Height="35" Width="35">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding UserModel.Avatar}"/>
                        </Border.Background>
                    </Border>
                    <Button Margin="10,0,0,0" Cursor="Hand"
                            VerticalAlignment="Center" Foreground="White"
                            Name="btnUserInfo">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{Binding UserModel.UserName}" ></TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <!--标签页-->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <RadioButton IsChecked="True" Content="首页" Style="{StaticResource NavButtonStyle}"
                                     Command="{Binding NavChangedCommand}"
                                     CommandParameter="HomePageView"/>
                    <RadioButton Content="课程中心" Style="{StaticResource NavButtonStyle}"
                                     Command="{Binding NavChangedCommand}"
                                     CommandParameter="CoursePageView"/>
                    <RadioButton Content="诚聘英才" Style="{StaticResource NavButtonStyle}"
                                     Command="{Binding NavChangedCommand}"
                                     CommandParameter="RecruitmentPageView"/>
                    <RadioButton Content="关于我们" Style="{StaticResource NavButtonStyle}"
                                     Command="{Binding NavChangedCommand}"
                                     CommandParameter="AboutUsPageView"/>
                    <RadioButton Content="个人中心" Style="{StaticResource NavButtonStyle}"
                                     Command="{Binding NavChangedCommand}"
                                     CommandParameter="PersonalCenterPageView"/>
                </StackPanel>
                <!--搜索块-->
                <TextBox Template="{StaticResource SearchTextBoxTemplate}" Grid.Row="1" Width="300" Height="32"
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Right"
                             Foreground="White"/>
                <ContentControl Grid.Row="2" Margin="0,15,0,0"
                                    Content = "{Binding MainContent}">
                </ContentControl>
            </Grid>
            <!--用户侧边栏-->
            <Border Opacity="0.9" CornerRadius="0,20,20,0" Width="240" HorizontalAlignment="Right">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="Gray" Offset="0"/>
                        <GradientStop Color="White" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <!--移动-->
                <Border.RenderTransform>
                    <TranslateTransform X ="245" x:Name="tt"/>
                </Border.RenderTransform>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <!--关闭按钮-->
                    <Button Width="35" Height="35" VerticalAlignment="Top" HorizontalAlignment="Left"
                              Name="btnCloseUserInfo"
                              Content="&#xe660;" Style="{StaticResource WindowControlButtonStyle}">
                    </Button>
                    <Border CornerRadius="50" Width="80" Height="80">
                        <Border.Background>
                            <ImageBrush  ImageSource="{Binding UserModel.Avatar}"/>
                        </Border.Background>
                    </Border>
                    <Grid Grid.Row="1"  Margin="10,0"  Height="300" VerticalAlignment="Top" HorizontalAlignment="Left">
                        <Grid.Resources>
                            <Style TargetType="RadioButton">
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="50"/>
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="账号"></TextBlock>
                            <TextBlock Text="{Binding UserModel.Account}" ></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Row="1"  VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="昵称"></TextBlock>
                            <TextBlock Text="{Binding UserModel.UserName}" ></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Row="2" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock  Text="性别"></TextBlock>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="男" Template="{DynamicResource GenderRadioButtonTemplate}" IsEnabled="False" IsChecked="{Binding UserModel.Gender, Converter={StaticResource GenderConverter}, ConverterParameter=Man}"/>
                                <RadioButton Content="女" Template="{DynamicResource GenderRadioButtonTemplate}"  IsEnabled="False"  IsChecked="{Binding UserModel.Gender, Converter={StaticResource GenderConverter}, ConverterParameter=Woman}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Row="3" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="邮箱"></TextBlock>
                            <TextBlock Text="{Binding UserModel.Email}" ></TextBlock>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
