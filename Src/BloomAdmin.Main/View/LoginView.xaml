<Window x:Class="BloomAdmin.Main.View.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BloomAdmin.Main.View"
        xmlns:common ="clr-namespace:BloomAdmin.Main.Common"
        mc:Ignorable="d" Name="window"
        Title="系统登录" Height="600" Width="360"
        FontFamily="Microsoft YaHei" FontWeight = "ExtraLight"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}" Loaded="window_Loaded">
    <Window.Resources>
        <ResourceDictionary Source="/Styles/DefaultStyle.xaml">
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
                    <!-- 嵌入资源：须写完整 pack URI；元素内不要换行缩进，否则会变成字体名的一部分 -->
                    <FontFamily x:Key="IconFont">pack://application:,,,/BloomAdmin.Main;component/Assets/Fonts/iconfont.ttf#iconfont</FontFamily>
                    <!-- 整行外框 -->
                    <Style x:Key="LoginInputRowBorder" TargetType="Border">
                        <Setter Property="BorderBrush" Value="#DDDDDD"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="6"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="Background" Value="#FAFAFA"/>
                        <Setter Property="Margin" Value="0,5"/>
                    </Style>
                    <Style x:Key="LoginRowIcon" TargetType="TextBlock">
                        <Setter Property="Grid.Column" Value="0"/>
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="FontSize" Value="25"/>
                        <Setter Property="Opacity" Value="0.3"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="0,5,0,0"/>
                        <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
                    </Style>
                    <!-- 和外框叠在一起时，常去掉输入框自带边框 -->
                    <Style x:Key="LoginRowTextBox" TargetType="TextBox">
                        <Setter Property="Margin" Value="10,0,0,0"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Grid.Column" Value="1"/>
                        <Setter Property= "VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="5,0,0,0"/>
                        <Setter Property="Height" Value="30"/>
                        <!--<Setter Property="Background" Value="#4DC7C7C7"/>-->
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Text" Value="10"/>
                    </Style>
                    <!-- 密码框 -->
                    <Style x:Key="LoginRowPasswordBox" TargetType="PasswordBox">
                        <Setter Property="Margin" Value="10,0,0,0"/>
                        <Setter Property="Grid.Column" Value="1"/>
                        <Setter Property= "VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="5,0,0,0"/>
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style x:Key="LoginRowPasswordTextBox" TargetType="TextBox">
                        <Setter Property="Margin" Value="10,0,0,0"/>
                        <Setter Property="Grid.Column" Value="1"/>
                        <Setter Property= "VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="5,0,0,0"/>
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <!-- 验证码输入框 -->
                    <Style x:Key="CaptchaInputTextBox" TargetType="TextBox">
                        <Setter Property="Margin" Value="10,0,0,0"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="Grid.Column" Value="1"/>
                        <Setter Property= "VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="5,0,0,0"/>
                        <Setter Property="Text" Value="10"/>
                    </Style>

                    <!-- 验证码：自定义模板，仅边框 + 图片，无默认按钮底纹 -->
                    <ControlTemplate TargetType="Button" x:Key="CaptchaViewTemplete">
                        <Grid>
                            <!-- 默认隐藏文字 -->
                            <TextBlock x:Name="DefaultText"
                               Text="{TemplateBinding Tag}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="15"
                               Foreground="Green"
                               Visibility="Collapsed"/>
                            <!-- 默认显示图片（即使为 null，也占位）-->
                            <Image x:Name="CaptchaImg"
                               Source="{Binding LoginModel.CaptchaImage}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="Visible"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- 仅当图片为 null 时：显示文字，隐藏图片 -->
                            <Trigger SourceName="CaptchaImg" Property="Source" Value="{x:Null}">
                                <Setter TargetName="DefaultText" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CaptchaImg" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    <!--密码显示隐藏按钮样式-->
                    <ControlTemplate TargetType="ToggleButton" x:Key="EyeToggleButtonTemplate">
                        <Border x:Name="Chrome" CornerRadius="10">
                            <TextBlock x:Name="Icon" 
                                   FontFamily="{StaticResource IconFont}" 
                                   FontSize="20"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Text="&#xe611;"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Icon" Property="Text" Value="&#xe610;"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>

                    <!-- 其他登录Icon -->
                    <Style x:Key="OtherLoginIcon" TargetType="TextBlock">
                        <Setter Property="Grid.Column" Value="0"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Width" Value="40"/>
                        <Setter Property="FontSize" Value="35"/>
                        <Setter Property="Opacity" Value="0.3"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
                    </Style>

                    <!-- 实心按钮需在模板里改 Background，否则默认模板不响应悬浮 -->
                    <Style x:Key="LoginPrimaryButton" TargetType="Button">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#FF2F3EFF"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Chrome"
                           Background="{TemplateBinding Background}"
                           CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="#FF4B58FF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="#FF252FCC"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Margin="5,5" Background="White" CornerRadius="15"
             MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Gray" ShadowDepth="0" BlurRadius="3" Direction="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>
            <Border Margin="0,0,0,0" Grid.Row="0" Background="#FF2F3EFF" CornerRadius="15,15,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" ShadowDepth="0" BlurRadius="5" Direction="0"/>
                </Border.Effect>
            </Border>
            <Button Margin="0,5,5,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="40" Height="30"
               Style="{StaticResource WindowControlButtonStyle}"
               Content="&#xe660;"
               Command="{Binding CloseWindowCommand}"
               CommandParameter="{Binding ElementName=window}">
            </Button>

            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,0">
                <Border Background="White" VerticalAlignment="Center" HorizontalAlignment="Center" 
                        CornerRadius="50" Width="80" Height="80">
                    <Border.Effect>
                        <DropShadowEffect Color="White" ShadowDepth="0" BlurRadius="3" Direction="0"/>
                    </Border.Effect>
                    <Border Width="90" Height="80" CornerRadius="50" HorizontalAlignment="Center">
                        <Border.Background>
                            <ImageBrush ImageSource="pack://application:,,,/BloomAdmin.Main;component/Assets/Images/Logo.png"/>
                        </Border.Background>
                    </Border>
                </Border>
                <TextBlock Margin="0,20,0,30" Text="朝夕教育管理平台" HorizontalAlignment="Center" Foreground="White" FontSize="18"></TextBlock>
                <Border Height="4" ClipToBounds="True">
                    <ProgressBar VerticalAlignment="Stretch"
                                 IsIndeterminate="{Binding IsLoading}"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                 Foreground="Orange"/>
                </Border>
            </StackPanel>
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition MinHeight="20" Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource LoginInputRowBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource LoginRowIcon}" Text="&#xe61d;"/>
                        <TextBox x:Name="AccountTextBox" 
                                 Text="{Binding LoginModel.Account, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource LoginRowTextBox}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoginCommand}"
                                            CommandParameter="{Binding ElementName=window}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource LoginInputRowBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="35"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource LoginRowIcon}" Text="&#xe623;"/>
                        <PasswordBox Name="PasswordBox"
                            Style="{StaticResource LoginRowPasswordBox}" 
                            common:PasswordHelper.Attach="True" 
                            common:PasswordHelper.Password="{Binding LoginModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <PasswordBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoginCommand}"
                                CommandParameter="{Binding ElementName=window}"/>
                            </PasswordBox.InputBindings>
                        </PasswordBox>
                        <TextBox Name="PasswordTextBox"
                                Text="{Binding LoginModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource LoginRowPasswordTextBox}"
                                Visibility="Hidden">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoginCommand}"
                                CommandParameter="{Binding ElementName=window}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <ToggleButton Grid.Column="2" 
                                      Template="{StaticResource EyeToggleButtonTemplate}" 
                                      KeyboardNavigation.IsTabStop="False"
                                      Checked="ToggleButton_Checked" 
                                      Unchecked="ToggleButton_Unchecked"/>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource LoginInputRowBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="105"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource LoginRowIcon}" Text="&#xe708;"/>
                        <TextBox Text="{Binding LoginModel.CaptchaCode, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource CaptchaInputTextBox}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LoginCommand}"
                                  CommandParameter="{Binding ElementName=window}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column ="2"
                                Template="{StaticResource CaptchaViewTemplete}"
                                Command="{Binding CaptchaCommand}"
                                Tag="点击刷新"/>
                    </Grid>
                </Border>
                <Button Grid.Row="3" Height="40" Content="登     录"
                        Style="{StaticResource LoginPrimaryButton}"
                        Command="{Binding LoginCommand}"
                        KeyboardNavigation.IsTabStop="False"/>
                <TextBlock Grid.Row="4" Height="20"
                           Text="{Binding ErrorMessage}"
                           FontSize="12" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{Binding ErrorMessageColor}"/>
            </Grid>
            <Grid Grid.Row="2" Margin="20,0,20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,0,1" VerticalAlignment="Center"></Border>
                    <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="0,0,0,1" VerticalAlignment="Center"></Border>
                    <TextBlock Grid.Column="1" Text="OR" Foreground="#DDD" Margin="5" VerticalAlignment="Center"></TextBlock>
                </Grid>
                <UniformGrid Grid.Row="1" Columns="5" Margin="30,0" KeyboardNavigation.IsTabStop="False">
                    <TextBlock  Style="{StaticResource OtherLoginIcon}" Text="&#xe654;"></TextBlock>
                    <TextBlock></TextBlock>
                    <TextBlock Style="{StaticResource OtherLoginIcon}" Text="&#xe62c;"></TextBlock>
                    <TextBlock></TextBlock>
                    <TextBlock Style="{StaticResource OtherLoginIcon}" Text="&#xe602;"></TextBlock>
                </UniformGrid>
            </Grid>
        </Grid>
    </Border>
</Window>
