<UserControl x:Class="BloomAdmin.Main.View.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BloomAdmin.Main.View"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:cuscon="clr-namespace:BloomAdmin.Main.View.CustomControls"
             mc:Ignorable="d" 
             FontFamily="Microsoft YaHei" FontWeight = "ExtraLight"
             d:MinHeight="600" d:MinWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="IconFont">pack://application:,,,/BloomAdmin.Main;component/Assets/Fonts/iconfont.ttf#iconfont</FontFamily>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="0.28*"/>
            <RowDefinition Height="0.60*"/>
            <RowDefinition Height="0.12*"/>
        </Grid.RowDefinitions>
        <UniformGrid Columns="4">
            <cuscon:MetricCard  Margin="5" 
                                TopIcon="&#xe662;"
                                FillColor="#336ED25A"
                                StrokeColor="Green"
                                TopTextContent="25%"
                                ButtomIcon="&#xe662;"
                                ButtomTextContent1="CPU使用情况"
                                ButtomTextContent2="25%"
                                ChartValues = "{Binding DefaultData1}"/>
            <cuscon:MetricCard  Margin="5" 
                                TopIcon="&#xe662;"
                                FillColor="#33F7C75F"
                                StrokeColor="Orange"
                                TopTextContent="25%"
                                ButtomIcon="&#xe662;"
                                ButtomTextContent1="内存占用情况"
                                ButtomTextContent2="70%"
                                ChartValues = "{Binding DefaultData2}"/>
            <cuscon:MetricCard  Margin="5" 
                                TopIcon="&#xe662;"
                                FillColor="#33F36E50"
                                StrokeColor="Red"
                                TopTextContent="25%"
                                ButtomIcon="&#xe662;"
                                ButtomTextContent1="营收增长率"
                                ButtomTextContent2="41.2%"
                                ChartValues = "{Binding DefaultData3}"/>
                    <cuscon:MetricCard  Margin="5" 
                                TopIcon="&#xe662;"
                                FillColor="#3350B4F3"
                                StrokeColor="Blue"
                                TopTextContent="25%"
                                ButtomIcon="&#xe662;"
                                ButtomTextContent1="当天营收"
                                ButtomTextContent2="¥5001"
                                ChartValues = "{Binding DefaultData4}"/>
        </UniformGrid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel Margin="5" Background="Blue"></StackPanel>
                <StackPanel Margin="5" Grid.Row="1" Background="Yellow"></StackPanel>
            </Grid>
            <Border Grid.Column="1" Margin="5" CornerRadius="10" Background="Green">
            </Border>
        </Grid>
        <Grid Grid.Row="2">
            <StackPanel>
                <TextBlock Text="这是一个文本块" Foreground="White" FontSize="20" FontWeight="Bold" Margin="5"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
