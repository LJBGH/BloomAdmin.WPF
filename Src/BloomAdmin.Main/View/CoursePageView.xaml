<UserControl x:Class="BloomAdmin.Main.View.CoursePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BloomAdmin.Main.View"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="800"
             FontFamily="Microsoft YaHei" FontWeight = "ExtraLight"
             FontSize="12">
    <UserControl.Resources>
        <FontFamily x:Key="IconFont">pack://application:,,,/BloomAdmin.Main;component/Assets/Fonts/iconfont.ttf#iconfont</FontFamily>
        <ControlTemplate TargetType="RadioButton" x:Key="CategoryRadioButtonTemplate">
            <Grid Background="Transparent">
                <Border CornerRadius="5" Background="Gray" x:Name="back">
                    <TextBlock Margin="10,3" Text="{TemplateBinding Content}" 
                               VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                </Border>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" TargetName="back" Value="Orange"></Setter>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Background" TargetName="back" Value="Gray"></Setter>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>
    <Grid Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Margin="10,10">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid Height="40" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" >
                        <TextBlock Text=" 课程分类" TextAlignment="Center" Margin="0,0,20,0" VerticalAlignment="Center"></TextBlock>
                        <ItemsControl ItemsSource="{Binding CourseCategory}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"></StackPanel>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton GroupName="CourseCategory" Margin="5,0" 
                                                 Template="{StaticResource CategoryRadioButtonTemplate}"
                                                 IsChecked="{Binding IsChecked}" 
                                                 Content="{Binding CategoryName}"
                                                 Command="{Binding DataContext.CategorySwitchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding CategoryName}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Height="40" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" >
                        <TextBlock Text=" 技术分类" TextAlignment="Center" Margin="0,0,20,0" VerticalAlignment="Center"></TextBlock>
                        <ItemsControl ItemsSource="{Binding TechnologyCategory}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"></StackPanel>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton GroupName="TechnologyCategory" Margin="5,0" 
                                                 Template="{StaticResource CategoryRadioButtonTemplate}" 
                                                 IsChecked="{Binding IsChecked}" 
                                                 Content="{Binding CategoryName}"
                                                 Command="{Binding DataContext.CategorySwitchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding CategoryName}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="2" Height="40" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" >
                        <TextBlock Text=" 授课老师" TextAlignment="Center" Margin="0,0,20,0" VerticalAlignment="Center"></TextBlock>
                        <ItemsControl ItemsSource="{Binding TeacherCategory}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"></StackPanel>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton GroupName="TeacherCategory" Margin="5,0" 
                                                 Template="{StaticResource CategoryRadioButtonTemplate}" 
                                                 IsChecked="{Binding IsChecked}" 
                                                 Content="{Binding CategoryName}"
                                                 Command="{Binding DataContext.CategorySwitchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding CategoryName}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
                <Button Grid.Row="2" Height="25" Width="80" HorizontalAlignment="Right" Margin="0,0,30,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xe60d;" FontFamily="{StaticResource IconFont}" FontSize="15" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Margin="5,0,0,0" Text="添加课程"/>
                    </StackPanel>
                </Button>
            </Grid>
            <Border Grid.Row="1" Background="Gray" BorderThickness="0.1" ></Border>
            <Grid Grid.Row="2" Margin="10,10" Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CourseItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="80" Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <!--封面区-->
                                        <Border CornerRadius="5" ClipToBounds ="True">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding CoverUrl}" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="30,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock  FontSize="18" VerticalAlignment="Center" >
                                                 <Hyperlink Foreground="#333" FontWeight="Bold"
                                                            Command="{Binding DataContext.OpenCourseLinkCommand, RelativeSource={RelativeSource AncestorType={x:Type local:CoursePageView}}}"
                                                            CommandParameter="{Binding CourseUrl}">
                                                     <Hyperlink.Style>
                                                         <Style>
                                                             <Setter Property="TextBlock.TextDecorations" Value="{x:Null}"/>
                                                             <Style.Triggers>
                                                                 <Trigger Property="Hyperlink.IsMouseOver" Value="True">
                                                                     <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                                                                 </Trigger> 
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Hyperlink.Style>
                                                     <TextBlock Text="{Binding CourseName}"/>
                                                 </Hyperlink>
                                             </TextBlock>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal" VerticalAlignment="Center" >
                                                    <ItemsControl ItemsSource="{Binding Teachers}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="10,0" Background="Gray" CornerRadius="5" >
                                                                    <TextBlock Margin="8,3" Text="{Binding}"></TextBlock>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Margin="0,8,0,0" Foreground="#333" Text="{Binding CourseDescription}" 
                                            TextWrapping="Wrap" LineHeight="15"></TextBlock>
                                        </StackPanel>

                                        <!--操作区-->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Margin="10,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                             <Hyperlink>详情</Hyperlink>
                                            </TextBlock>
                                            <TextBlock Margin="10,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                             <Hyperlink>删除</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
