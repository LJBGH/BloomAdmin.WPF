<UserControl x:Class="BloomAdmin.Main.View.CustomControls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BloomAdmin.Main.View.CustomControls"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             MinHeight="160"
             MinWidth="200"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch" >
    <UserControl.Resources>
        <FontFamily x:Key="IconFont">pack://application:,,,/BloomAdmin.Main;component/Assets/Fonts/iconfont.ttf#iconfont</FontFamily>
    </UserControl.Resources>
    <Border Background="White" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#FF4646B9" BlurRadius="10" ShadowDepth="3"/>
        </Border.Effect>
        <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:MetricCard}}}">
            <!--图表-->
            <lvc:CartesianChart Margin="0,0,0,40">
                <lvc:CartesianChart.Series>
                    <lvc:LineSeries
                     Stroke="{Binding StrokeColor}"
                     Fill="{Binding FillColor}"
                     PointGeometrySize="0"
                     Values="{Binding ChartValues}" />
                </lvc:CartesianChart.Series>
                <lvc:CartesianChart.AxisX>
                    <lvc:Axis ShowLabels="{Binding XShowLabels}"></lvc:Axis>
                </lvc:CartesianChart.AxisX>
                <lvc:CartesianChart.AxisY>
                    <lvc:Axis ShowLabels="{Binding YShowLabels}"
                              MinValue="0" MaxValue="100"></lvc:Axis>
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>
            <!--上方数据-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0">
                <Border Background="{Binding FillColor}" Width="25" Height="25" CornerRadius="5">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" 
                               Foreground="{Binding StrokeColor}" 
                               FontFamily="{StaticResource IconFont}"
                               Text="{Binding TopIcon}"/>
                </Border>
                <TextBlock Margin="15,0" 
                           Text="{Binding TopTextContent}"
                           Foreground="{Binding StrokeColor}" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"></TextBlock>
            </StackPanel>
            <!--下方数据-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,0">
                <Border Background="{Binding FillColor}" 
                        Width="30" Height="30" CornerRadius="5">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" 
                        Text="{Binding ButtomIcon}"       
                        Foreground="{Binding StrokeColor}" 
                        FontFamily="{StaticResource IconFont}"></TextBlock>
                </Border>
                <StackPanel Margin="15,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ButtomTextContent1}" 
                               FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Left"></TextBlock>
                    <TextBlock Text="{Binding ButtomTextContent2}"
                               FontWeight="Bold" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Left"></TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
