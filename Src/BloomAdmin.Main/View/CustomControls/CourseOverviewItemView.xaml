<UserControl x:Class="BloomAdmin.Main.View.CustomControls.CourseOverviewItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BloomAdmin.Main.View.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="36" d:DesignWidth="50"
             FontSize="10"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <FontFamily x:Key="IconFont">pack://application:,,,/BloomAdmin.Main;component/Assets/Fonts/iconfont.ttf#iconfont</FontFamily>

        <!-- 方案1：按 ItemStatus 切换图标码点与颜色（示例：0=绿升 1=橙平 2=红降，可按业务改 Value） -->
        <Style x:Key="StatusIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="Foreground" Value="#FF4CAF50"/>
            <Setter Property="Text" Value="&#xe622;"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ItemStatus}" Value="1">
                    <Setter Property="Text" Value="&#xe624;"/>
                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ItemStatus}" Value="2">
                    <Setter Property="Text" Value="&#xe622;"/>
                    <Setter Property="Foreground" Value="#FFF44336"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusDeltaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF4CAF50"/>
            <Setter Property="Text" Value="-0%"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ItemStatus}" Value="1">
                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ItemStatus}" Value="2">
                    <Setter Property="Foreground" Value="#FFF44336"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:CourseOverviewItemView}}}">
        <StackPanel Orientation="Horizontal">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding ItemName}"></TextBlock>
                <TextBlock Text="{Binding ItemCount}"></TextBlock>
            </StackPanel>
            <StackPanel Margin="5,0,0,0" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource StatusIconTextStyle}"/>
                <TextBlock Margin="0,1,0,0"
                           Style="{StaticResource StatusDeltaTextStyle}"
                           Text="{Binding ItemPercent}"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
